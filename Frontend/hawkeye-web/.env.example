# ─────────────────────────────────────────────────────────────────────────────
# Hawkeye Frontend — copy to .env.local and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace_with_random_secret
NEXTAUTH_URL=http://localhost:3000

# ── Backend API ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Shared secrets (must match Backend/.env) ─────────────────────────────────
# Used by Next.js API routes (server-side only) — never exposed to the browser
HAWKEYE_INTERNAL_SECRET=replace_with_random_hex_32

# ── Google OAuth ──────────────────────────────────────────────────────────────
# https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# https://github.com/settings/developers → OAuth Apps
GITHUB_ID=
GITHUB_SECRET=
