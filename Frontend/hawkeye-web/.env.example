NEXTAUTH_SECRET="generate-a-random-secret"

# When running locally:
NEXTAUTH_URL="http://localhost:3000"

# Backend API URL (Next.js public)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend auth secrets (generate with: openssl rand -hex 32)
# HAWKEYE_AUTH_SECRET signs backend JWTs; omit to run in dev mode (no auth enforced)
HAWKEYE_AUTH_SECRET=""
# HAWKEYE_INTERNAL_SECRET is shared between Next.js server and FastAPI for OAuth token exchange
HAWKEYE_INTERNAL_SECRET=""

# Google OAuth (SSO)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth (SSO)
GITHUB_ID=""
GITHUB_SECRET=""

