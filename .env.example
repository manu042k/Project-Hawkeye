## Hawkeye example env (copy to .env)

# Website Chrome should open on boot.
CHROME_URL="https://example.com/"

# If your app needs a Google API key (Maps, etc.), set it here.
GOOGLE_API_KEY="REPLACE_ME"

# Groq API key for LLM planning (OpenAI-compatible endpoint).
GROQ_API_KEY="REPLACE_ME"

# Hawkeye API
HAWKEYE_DB_URL=postgres://hawkeye:hawkeye@localhost:5432/hawkeye
HAWKEYE_SANDBOX_IMAGE=project-hawkeye-hawkeye-sandbox:latest
FIGMA_URL=
FIGMA_TOKEN=
NVIDIA_API_KEY=

