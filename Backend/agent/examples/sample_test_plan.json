{
  "url_to_test": "https://www.amazon.com/",
  "browser": "chromium",
  "viewport": {
    "width": 1366,
    "height": 768
  },
  "test_cases": [
    {
      "test_id": "tc-amazon-iphone-cart",
      "test_name": "Open Amazon, search iPhone, add first in-grid result to cart, open cart and verify iPhone in cart",
      "assertions": [
        {
          "type": "url_contains",
          "value": "amazon"
        },
        {
          "type": "url_contains",
          "value": "cart"
        },
        {
          "type": "text_present",
          "value": "iPhone"
        }
      ],
      "actions": [
        {
          "type": "navigate",
          "url": "https://www.amazon.com/",
          "reason": "open Amazon home"
        },
        {
          "type": "wait",
          "seconds": 2.0,
          "reason": "allow homepage and search chrome to settle"
        },
        {
          "type": "type",
          "selector": "#twotabsearchtextbox",
          "text": "iphone",
          "reason": "enter search query for iPhone"
        },
        {
          "type": "click",
          "selector": "#nav-search-submit-button",
          "reason": "submit search"
        },
        {
          "type": "wait",
          "seconds": 3.0,
          "reason": "wait for search results"
        },
        {
          "type": "scroll",
          "pixels": 400,
          "reason": "bring first product row into view for add-to-cart"
        },
        {
          "type": "click",
          "selector": "div.s-main-slot div[data-component-type=\"s-search-result\"] input[name=\"submit.addToCart\"]",
          "reason": "add first search-result card that exposes add-to-cart on the results page"
        },
        {
          "type": "wait",
          "seconds": 2.0,
          "reason": "allow add-to-cart confirmation or mini-cart to update"
        },
        {
          "type": "navigate",
          "url": "https://www.amazon.com/gp/cart/view.html",
          "reason": "open shopping cart to verify line items"
        },
        {
          "type": "wait",
          "seconds": 2.0,
          "reason": "allow cart page to render"
        }
      ],
      "additional_context": {
        "notes": "Amazon markup and regional cookie banners vary; adjust selectors if a step fails on your locale."
      }
    }
  ]
}
