# Hawkeye local environment — NOT committed to git
GROQ_API_KEY=<your-groq-api-key>

# OpenRouter — alternative cloud provider (https://openrouter.ai/keys)
# Usage: python -m orchestrator run --test ... --model openrouter:<provider/model>
# Example models: anthropic/claude-3-5-haiku, meta-llama/llama-3.3-70b-instruct, openai/gpt-4o-mini
OPENROUTER_API_KEY=<your-openrouter-api-key>

# Container pool — set to 0 (default) to disable in dev, 2+ in production
HAWKEYE_POOL_SIZE=0