# ─────────────────────────────────────────────────────────────────────────────
# Hawkeye Backend — copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL (recommended for production). Omit to fall back to SQLite.
HAWKEYE_DB_URL=postgresql://hawkeye:hawkeye@localhost:5432/hawkeye

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth / Security ───────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
HAWKEYE_AUTH_SECRET=replace_with_random_hex_32
# Shared with Next.js for OAuth token exchange — must match frontend value
HAWKEYE_INTERNAL_SECRET=replace_with_random_hex_32
# Encryption key for Vault secrets (AES-256-GCM). Generate: openssl rand -hex 32
VAULT_ENCRYPTION_KEY=replace_with_random_hex_32

# ── Dev user (seeded on startup in dev mode) ──────────────────────────────────
HAWKEYE_DEV_EMAIL=dev@hawkeye.local
HAWKEYE_DEV_PASSWORD=devpassword

# ── LLM Providers ─────────────────────────────────────────────────────────────
# NVIDIA NIM — https://build.nvidia.com/
NVIDIA_API_KEY=

# OpenRouter — https://openrouter.ai/keys
# Example: --model openrouter:anthropic/claude-3-5-haiku
OPENROUTER_API_KEY=

# Groq — https://console.groq.com/
GROQ_API_KEY=

# vLLM — local inference server base URL (default: http://localhost:8001)
VLLM_BASE_URL=

# ── Sandbox ───────────────────────────────────────────────────────────────────
HAWKEYE_SANDBOX_IMAGE=project-hawkeye-hawkeye-sandbox:latest
# Pre-warm N sandbox containers (0 = disabled in dev)
HAWKEYE_POOL_SIZE=0
# Override Chrome DevTools Protocol URL (leave blank to use sandbox default)
HAWKEYE_CDP_URL=

# ── Artifact storage ──────────────────────────────────────────────────────────
# "local" (default) or "s3"
ARTIFACT_STORE=local
ARTIFACT_DIR=artifacts

# ── GitHub integration ────────────────────────────────────────────────────────
GITHUB_WEBHOOK_SECRET=
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_APP_ID=
GITHUB_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=
# SHA injected by CI to link runs to commits
GITHUB_HEAD_SHA=

# ── Slack notifications ───────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
# Set to 1 to send Slack notification on pass as well
SLACK_NOTIFY_PASS=0

# ── Stripe billing ────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_TEAM_PRICE_ID=

# ── Misc ──────────────────────────────────────────────────────────────────────
# Enforce plan run limits (0 = disabled in dev)
HAWKEYE_PLAN_ENFORCE=0
HAWKEYE_DEFAULT_PLAN=pro
HAWKEYE_WEBHOOK_TOKEN=
APP_URL=http://localhost:8000

# ── Observability (Track E — optional) ───────────────────────────────────────
PHOENIX_COLLECTOR_ENDPOINT=
